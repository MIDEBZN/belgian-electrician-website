    ]
  }
};

const breadcrumbItems = currentPath === '/' ? [] : currentPath.split('/').filter(Boolean).map((segment, index, arr) => ({
  "@type": "ListItem",
  "position": index + 2,
  "name": segment.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()),
  "item": `https://www.allo-electricien.be/${arr.slice(0, index + 1).join('/')}`
}));

const breadcrumbSchema = breadcrumbItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://www.allo-electricien.be/" },
    ...breadcrumbItems
  ]
} : null;

---

<Layout title="Blog Électricité Bruxelles — Conseils & Guides" description="Blog Allo Electricien : guides, conseils et actualités sur l'électricité à Bruxelles. Prix, normes RGIE, sécurité, domotique, bornes de recharge et plus.">

  <header class="relative bg-navy overflow-hidden pt-12 pb-24 border-b border-white/5">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#4a4a8a 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <nav aria-label="Breadcrumb" class="flex text-sm text-gray-400 mb-6">
        <ol class="flex items-center space-x-2">
          <li><a class="hover:text-primary" href="/">Accueil</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li class="text-primary font-medium">Blog</li>
        </ol>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 tracking-tight">
        Notre <span class="text-primary">Blog</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mt-4 leading-relaxed">
        Guides, conseils et actualités sur l'électricité à Bruxelles. Tout ce que vous devez savoir pour votre installation.
      </p>
    </div>
  </header>

  <main class="relative z-20 -mt-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {articles.map(article => (
        <a href={`/blog/${article.slug}`} class="group bg-navy rounded-2xl border border-white/10 overflow-hidden hover:border-primary/50 transition-all hover:-translate-y-1 shadow-xl">
          <div class="bg-navy-light p-8 flex items-center justify-center min-h-[200px]">
            <span class="material-icons text-primary text-6xl group-hover:scale-110 transition-transform">{article.icon}</span>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold text-primary bg-primary/10 px-3 py-1 rounded-full">{article.category}</span>
              <span class="text-xs text-gray-500">{article.readTime}</span>
            </div>
            <h2 class="text-lg font-bold text-white mb-2 group-hover:text-primary transition-colors">{article.title}</h2>
            <p class="text-sm text-gray-400 leading-relaxed">{article.description}</p>
            <div class="mt-4 flex items-center justify-between text-xs text-gray-500">
              <span>{new Date(article.date).toLocaleDateString('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              <span class="text-primary group-hover:translate-x-1 transition-transform material-icons text-sm">arrow_forward</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

</Layout>

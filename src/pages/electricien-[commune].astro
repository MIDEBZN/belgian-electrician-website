---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { communes } from '../data/communes';

export function getStaticPaths() {
  return communes.map(commune => ({
    params: { commune: commune.slug },
    props: { commune }
  }));
}

const { commune } = Astro.props;

// Get other communes for internal linking (random 12)
const otherCommunes = communes
  .filter(c => c.slug !== commune.slug)
  .sort(() => 0.5 - Math.random())
  .slice(0, 12);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Quel est le temps d'intervention d'un électricien à ${commune.name} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Notre temps moyen d'intervention à ${commune.name} (${commune.zip}) est de 30-45 minutes. Nous avons des techniciens basés localement pour garantir une intervention rapide.`
      }
    },
    {
      "@type": "Question",
      "name": `Combien coûte un électricien à ${commune.name} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Nos tarifs à ${commune.name} sont transparents : 45€/h en journée (+ 30€ déplacement), 75€/h le soir et samedi. Devis gratuit pour les travaux planifiés.`
      }
    },
    {
      "@type": "Question",
      "name": `Intervenez-vous pour la mise en conformité à ${commune.name} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Oui, nous réalisons la mise en conformité complète de votre installation électrique à ${commune.name}, y compris les plans unifilaires et la réception par l'organisme agréé.`
      }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Electrician",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Allo Electricien"
  },
  "areaServed": {
    "@type": "City",
    "name": commune.name
  },
  "description": `Électricien professionnel à ${commune.name}. Dépannage urgent, installation, mise en conformité RGIE.`
};

const allSchemas = [faqSchema, serviceSchema];
---

<Layout
  title={commune.title}
  description={commune.metaDescription}
  schema={allSchemas}
>

  <!-- Header -->
  <header class="relative bg-navy overflow-hidden pt-12 pb-24 border-b border-white/5">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#4a4a8a 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute right-0 top-0 w-1/3 h-full bg-gradient-to-l from-primary/10 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <nav aria-label="Breadcrumb" class="flex text-sm text-gray-300 mb-6">
        <ol class="flex items-center space-x-2">
          <li><a class="hover:text-primary" href="/">Accueil</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li><a class="hover:text-primary" href="/zones">Zones</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li class="text-primary font-medium">{commune.name}</li>
        </ol>
      </nav>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 tracking-tight">
        Électricien à <span class="text-primary">{commune.name}</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mt-4 leading-relaxed">
        Dépannage urgent 24/7, installation et mise en conformité à {commune.name} ({commune.zip}). Expert local agréé.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mt-8">
        <a href="tel:+32465732348" class="flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-navy font-bold px-8 py-4 rounded-xl transition-all hover:-translate-y-1 shadow-lg">
          <span class="material-icons">call</span>Appeler Maintenant
        </a>
        <a href="/contact" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-xl border border-white/20 transition-all">
          Devis Gratuit
        </a>
      </div>
    </div>
  </header>

  <main class="relative z-20 -mt-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">

    <!-- Key Info Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <div class="bg-navy rounded-xl border border-white/10 p-6 flex items-center gap-4 shadow-xl">
        <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary flex-shrink-0">
          <span class="material-icons">timer</span>
        </div>
        <div>
          <p class="font-bold text-white">30-45 Min</p>
          <p class="text-gray-300 text-sm">Arrivée rapide à {commune.name}</p>
        </div>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 flex items-center gap-4 shadow-xl">
        <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary flex-shrink-0">
          <span class="material-icons">location_on</span>
        </div>
        <div>
          <p class="font-bold text-white">{commune.zip} {commune.name}</p>
          <p class="text-gray-300 text-sm">Zone prioritaire</p>
        </div>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 flex items-center gap-4 shadow-xl">
        <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary flex-shrink-0">
          <span class="material-icons">schedule</span>
        </div>
        <div>
          <p class="font-bold text-white">24h/24 - 7j/7</p>
          <p class="text-gray-300 text-sm">Soirs et weekends inclus</p>
        </div>
      </div>
    </div>

    <!-- About Content -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20 items-center">
      <div>
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Service Local</span>
        <h2 class="text-3xl font-bold text-white mb-6">Votre Électricien de Confiance à {commune.name}</h2>
        <div class="space-y-4 text-gray-300 leading-relaxed text-lg">
          <p>{commune.aboutText}</p>
          <p>
            Nous couvrons l'ensemble des quartiers de {commune.name}, notamment : <strong class="text-white">{commune.neighborhoods.join(', ')}</strong>.
            Que vous soyez près de {commune.landmarks[0]} ou aux alentours de {commune.landmarks[1] || 'centre'}, nos techniciens mobiles interviennent rapidement.
          </p>
        </div>
        <ul class="mt-8 space-y-3">
            <li class="flex items-center gap-3 text-gray-300">
                <span class="material-icons text-primary">check_circle</span>
                <span>Électriciens agréés familiers avec le bâti de {commune.name}</span>
            </li>
            <li class="flex items-center gap-3 text-gray-300">
                <span class="material-icons text-primary">check_circle</span>
                <span>Conformité RGIE garantie pour vente ou rénovation</span>
            </li>
            <li class="flex items-center gap-3 text-gray-300">
                <span class="material-icons text-primary">check_circle</span>
                <span>Devis transparents et sans surprise</span>
            </li>
        </ul>
      </div>
      <div class="relative bg-navy-light p-8 rounded-2xl border border-white/10">
        <h3 class="text-xl font-bold text-white mb-4">Pourquoi choisir Allo Electricien à {commune.name} ?</h3>
        <p class="text-gray-300 mb-6">
            Contrairement aux grandes plateformes impersonnelles, nous sommes un <strong>acteur local</strong> ancré dans le tissu économique de {commune.name}. 
            Nous comprenons les spécificités des habitations du code postal {commune.zip}, qu'il s'agisse de rénover une maison ancienne ou d'équiper une nouvelle construction.
        </p>
        <div class="grid grid-cols-2 gap-4">
            <div class="bg-navy p-4 rounded-lg">
                <span class="material-icons text-primary mb-2">speed</span>
                <p class="font-bold text-white">Rapidité</p>
                <p class="text-xs text-gray-500">Intervention locale</p>
            </div>
            <div class="bg-navy p-4 rounded-lg">
                <span class="material-icons text-primary mb-2">verified</span>
                <p class="font-bold text-white">Qualité</p>
                <p class="text-xs text-gray-500">Garantie 2 ans</p>
            </div>
        </div>
      </div>
    </section>

    <!-- Services Grid tailored to location -->
    <section class="mb-20">
      <div class="text-center mb-12">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Nos Solutions</span>
        <h2 class="text-3xl font-bold text-white mb-4">Services Électriques à {commune.name}</h2>
        <p class="text-gray-300 max-w-2xl mx-auto">Une gamme complète de services adaptés aux particuliers et professionnels de la région.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Dépannage -->
        <div class="bg-navy p-6 rounded-xl border border-white/5 hover:border-primary/50 transition-all group">
            <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-icons text-navy text-2xl">bolt</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Dépannage d'Urgence</h3>
            <p class="text-gray-300 text-sm mb-4">Coupure de courant, panne de tableau ou court-circuit ? Nos électriciens à {commune.name} interviennent 24h/24.</p>
            <ul class="text-sm text-gray-500 space-y-1">
                <li>• Recherche de panne</li>
                <li>• Remplacement disjoncteur</li>
                <li>• Sécurisation installation</li>
            </ul>
        </div>

        <!-- Rénovation -->
        <div class="bg-navy p-6 rounded-xl border border-white/5 hover:border-primary/50 transition-all group">
            <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-icons text-navy text-2xl">home_repair_service</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Rénovation Électrique</h3>
            <p class="text-gray-300 text-sm mb-4">Remise à neuf partielle ou totale de l'électricité pour votre maison ou appartement au code postal {commune.zip}.</p>
             <ul class="text-sm text-gray-500 space-y-1">
                <li>• Mise à la terre</li>
                <li>• Nouveaux circuits</li>
                <li>• Remplacement câblage</li>
            </ul>
        </div>

        <!-- Conformité -->
        <div class="bg-navy p-6 rounded-xl border border-white/5 hover:border-primary/50 transition-all group">
            <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-icons text-navy text-2xl">fact_check</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Mise en Conformité RGIE</h3>
            <p class="text-gray-300 text-sm mb-4">Indispensable pour la vente ou l'achat d'un bien à {commune.name}. Nous garantissons la réception.</p>
             <ul class="text-sm text-gray-500 space-y-1">
                <li>• Schémas unifilaires</li>
                <li>• Plans de position</li>
                <li>• Levée des infractions</li>
            </ul>
        </div>

        <!-- Bornes -->
        <div class="bg-navy p-6 rounded-xl border border-white/5 hover:border-primary/50 transition-all group">
            <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-icons text-navy text-2xl">ev_station</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Bornes de Recharge</h3>
            <p class="text-gray-300 text-sm mb-4">Installation de bornes pour véhicules électriques à domicile ou en entreprise à {commune.name}.</p>
             <ul class="text-sm text-gray-500 space-y-1">
                <li>• Wallbox & Bornes rapides</li>
                <li>• Gestion de charge</li>
                <li>• Câblage dédié</li>
            </ul>
        </div>
      
        <!-- Videophonie -->
        <div class="bg-navy p-6 rounded-xl border border-white/5 hover:border-primary/50 transition-all group">
            <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-icons text-navy text-2xl">videocam</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Parlophonie & Accès</h3>
            <p class="text-gray-300 text-sm mb-4">Sécurisez l'accès à votre immeuble ou maison à {commune.name} avec nos solutions modernes.</p>
        </div>

        <!-- Eclairage -->
        <div class="bg-navy p-6 rounded-xl border border-white/5 hover:border-primary/50 transition-all group">
            <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-icons text-navy text-2xl">lightbulb</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Éclairage LED</h3>
            <p class="text-gray-300 text-sm mb-4">Relamping et création d'ambiances lumineuses pour intérieurs et extérieurs.</p>
        </div>
      </div>
    </section>

    <!-- Detailed content for SEO (Bottom page) -->
    <section class="bg-navy-light rounded-2xl p-8 mb-20 border border-white/5">
        <h3 class="text-2xl font-bold text-white mb-4">Installation électrique à {commune.name} : ce qu'il faut savoir</h3>
        <div class="text-gray-300 space-y-4 columns-1 md:columns-2 gap-8 text-sm leading-relaxed">
            <p>
                Si vous résidez à {commune.name} (code postal {commune.zip}), sachez que les normes électriques sont strictes, régies par le RGIE (Règlement Général sur les Installations Électriques). 
                Que vous habitiez près de {commune.landmarks[0] || 'la mairie'} ou dans les quartiers résidentiels comme {commune.neighborhoods[0]}, toute modification importante de votre installation nécessite une conformité.
            </p>
            <p>
                De nombreux bâtiments à {commune.name} datent d'avant 1981, ce qui implique souvent l'absence de mise à la terre ou des tableaux électriques obsolètes. 
                Lors d'une vente immobilière à {commune.name}, un contrôle électrique est obligatoire. Si le rapport est négatif, l'acheteur a 18 mois pour se mettre en ordre.
            </p>
            <p>
                <strong>Allo Electricien</strong> vous accompagne dans toutes ces démarches. Nous connaissons les spécificités du réseau local et les interlocuteurs pour les réceptions (organismes de contrôle).
                Faire appel à un électricien local à {commune.name}, c'est s'assurer d'une intervention rapide en cas de panne, évitant des frais de déplacement excessifs.
            </p>
            <p>
                Nous intervenons également pour les professionnels et copropriétés de {commune.name}, assurant la maintenance des communs, des éclairages de secours et des systèmes de sécurité.
            </p>
        </div>
    </section>

    <!-- Internal Linking / Other Zones -->
    <section class="border-t border-white/10 pt-16">
        <h3 class="text-xl font-bold text-white mb-8 text-center">Nos autres zones d'intervention à proximité</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
            {otherCommunes.map(city => (
                <a href={`/electricien-${city.slug}`} class="block bg-navy p-3 rounded-lg border border-white/5 text-center hover:border-primary hover:text-primary transition-colors">
                    <span class="text-sm font-medium text-gray-300 group-hover:text-white">{city.name}</span>
                </a>
            ))}
        </div>
        <div class="text-center mt-8">
            <a href="/zones" class="inline-flex items-center gap-2 text-primary hover:text-white transition-colors font-semibold">
                Voir toutes les zones d'intervention <span class="material-icons text-sm">arrow_forward</span>
            </a>
        </div>
    </section>

  </main>

</Layout>

---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-electricien.jpg';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien coûte un électricien à Bruxelles ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le tarif d'un électricien à Bruxelles dépend du type d'intervention. Chez Allo Electricien, nos tarifs sont transparents : déplacement + première heure à tarif fixe. Standard : 65€/h, soirée/samedi : 95€/h, nuit/dimanche/férié : 130€/h. Devis gratuit pour les installations et mises en conformité."
      }
    },
    {
      "@type": "Question",
      "name": "Comment trouver un électricien agréé et fiable à Bruxelles ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pour trouver un électricien agréé à Bruxelles, vérifiez sa certification RGIE, ses avis clients et son expérience. Allo Electricien est un électricien recommandé à Bruxelles avec plus de 15 ans d'expérience, des certifications à jour et plus de 2000 clients satisfaits."
      }
    },
    {
      "@type": "Question",
      "name": "Votre électricien intervient-il le week-end et les jours fériés à Bruxelles ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, notre service d'électricien à Bruxelles est disponible 24h/24 et 7j/7, y compris les week-ends et jours fériés. Nos équipes de garde assurent une intervention rapide en moins de 45 minutes dans les 19 communes de Bruxelles."
      }
    },
    {
      "@type": "Question",
      "name": "Quelles garanties offre votre électricien à Bruxelles ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Toutes nos installations et réparations sont garanties 2 ans. En tant qu'électricien agréé à Bruxelles, nous utilisons uniquement du matériel certifié CE et respectons strictement les normes RGIE. Nous sommes assurés en responsabilité civile professionnelle."
      }
    },
    {
      "@type": "Question",
      "name": "Pourquoi choisir Allo Electricien comme électricien à Bruxelles ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Allo Electricien est le meilleur électricien à Bruxelles grâce à son intervention en moins de 45 minutes, ses prix transparents sans surprise, sa certification RGIE et ses 15+ années d'expérience. Consultez nos avis clients 5 étoiles pour vous en convaincre."
      }
    }
  ]
};
---

<Layout title="Électricien Bruxelles — Dépannage Urgent 24/7 | Allo Electricien" description="Allo Electricien, électricien agréé à Bruxelles. Meilleur électricien recommandé : dépannage urgent 24/7, installation, mise en conformité RGIE. Intervention en -45min. Avis 5★. ☎ 0465 73 23 48" schema={faqSchema}>

  <!-- Hero -->
  <section class="relative bg-navy overflow-hidden">
    <div class="absolute inset-0 opacity-20 hero-pattern"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy via-navy to-navy/80 z-10"></div>
    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 flex flex-col md:flex-row items-center">
      <div class="w-full md:w-1/2 text-center md:text-left mb-12 md:mb-0">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 text-primary text-sm font-bold mb-6 border border-primary/30">
          <span class="w-2 h-2 rounded-full bg-primary animate-ping"></span>
          DISPONIBLE MAINTENANT
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Votre <span class="text-primary">Électricien à Bruxelles</span> <br/>Disponible 24/7
        </h1>
        <p class="text-lg text-gray-200 mb-8 max-w-lg mx-auto md:mx-0">
          <strong class="text-white">Électricien agréé à Bruxelles</strong> — intervention rapide en moins de 45 minutes. Dépannage, installation, mise en conformité RGIE. L'électricien fiable et recommandé par plus de 2000 clients bruxellois.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a href="tel:+32465732348" class="flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-navy text-lg font-bold px-8 py-4 rounded-xl shadow-[0_0_20px_rgba(253,186,18,0.4)] transition-all hover:-translate-y-1">
            <span class="material-icons">call</span>
            Appeler Maintenant
          </a>
          <a href="/contact" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white text-lg font-semibold px-8 py-4 rounded-xl border border-white/20 transition-all">
            Demander un devis
          </a>
        </div>
      </div>
      <div class="w-full md:w-1/2 relative h-[400px] md:h-[500px] rounded-2xl overflow-hidden shadow-2xl border-4 border-navy-light/50">
        <Image 
          src={heroImage} 
          alt="Électricien professionnel au travail" 
          class="absolute inset-0 w-full h-full object-cover"
          widths={[400, 640, 800, 1024, heroImage.width]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-transparent opacity-60"></div>
        <div class="absolute bottom-6 left-6 right-6 bg-white/10 backdrop-blur-md p-4 rounded-xl border border-white/20 flex items-center gap-4">
          <div class="bg-green-500 rounded-full p-2">
            <span class="material-icons text-white">verified_user</span>
          </div>
          <div>
            <p class="text-white font-bold">Techniciens Agréés</p>
            <p class="text-gray-300 text-sm">Certification RGIE</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-navy-light border-y border-white/5 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="flex flex-col items-center">
          <div class="text-4xl font-bold text-primary mb-2">15+</div>
          <div class="text-gray-300 text-sm uppercase tracking-wider font-semibold">Années d'Expérience</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-4xl font-bold text-primary mb-2">2k+</div>
          <div class="text-gray-300 text-sm uppercase tracking-wider font-semibold">Clients Satisfaits</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-4xl font-bold text-primary mb-2">45m</div>
          <div class="text-gray-300 text-sm uppercase tracking-wider font-semibold">Temps Moyen</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-4xl font-bold text-primary mb-2">24/7</div>
          <div class="text-gray-300 text-sm uppercase tracking-wider font-semibold">Disponibilité</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pourquoi nous choisir -->
  <section class="py-20 bg-bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Électricien Fiable Bruxelles</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Pourquoi Choisir Allo Electricien ?</h2>
        <p class="text-gray-300 max-w-2xl mx-auto mt-3">Découvrez ce qui fait de nous le <strong class="text-white">meilleur électricien à Bruxelles</strong> — agréé, rapide et recommandé par des milliers de clients.</p>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full mt-4"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">

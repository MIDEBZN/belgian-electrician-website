          <a href="/services" class="text-accent-blue text-sm font-bold flex items-center gap-1 group-hover:translate-x-2 transition-transform">En savoir plus <span class="material-icons text-xs">arrow_forward_ios</span></a>
        </div>
        <div class="group bg-navy p-8 rounded-xl shadow-md border border-white/5 glow-hover transition-all duration-300">
          <div class="w-14 h-14 bg-primary rounded-lg flex items-center justify-center mb-6 shadow-lg shadow-primary/30 group-hover:scale-110 transition-transform">
            <span class="material-icons text-navy text-3xl">check_circle</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Mise en Conformité</h3>
          <p class="text-gray-300 text-sm mb-4">Préparation aux contrôles, schémas unifilaires et mise aux normes RGIE pour la vente.</p>
          <a href="/services" class="text-accent-blue text-sm font-bold flex items-center gap-1 group-hover:translate-x-2 transition-transform">En savoir plus <span class="material-icons text-xs">arrow_forward_ios</span></a>
        </div>
        <div class="group bg-navy p-8 rounded-xl shadow-md border border-white/5 glow-hover transition-all duration-300">
          <div class="w-14 h-14 bg-primary rounded-lg flex items-center justify-center mb-6 shadow-lg shadow-primary/30 group-hover:scale-110 transition-transform">
            <span class="material-icons text-navy text-3xl">lightbulb</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Éclairage LED</h3>
          <p class="text-gray-300 text-sm mb-4">Solutions d'éclairage intérieur et extérieur économiques et esthétiques pour votre habitat.</p>
          <a href="/services" class="text-accent-blue text-sm font-bold flex items-center gap-1 group-hover:translate-x-2 transition-transform">En savoir plus <span class="material-icons text-xs">arrow_forward_ios</span></a>
        </div>
        <div class="group bg-navy p-8 rounded-xl shadow-md border border-white/5 glow-hover transition-all duration-300">
          <div class="w-14 h-14 bg-primary rounded-lg flex items-center justify-center mb-6 shadow-lg shadow-primary/30 group-hover:scale-110 transition-transform">
            <span class="material-icons text-navy text-3xl">router</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Domotique</h3>
          <p class="text-gray-300 text-sm mb-4">Installation de systèmes intelligents pour le contrôle à distance de votre maison.</p>
          <a href="/services" class="text-accent-blue text-sm font-bold flex items-center gap-1 group-hover:translate-x-2 transition-transform">En savoir plus <span class="material-icons text-xs">arrow_forward_ios</span></a>
        </div>
        <div class="group bg-navy p-8 rounded-xl shadow-md border border-white/5 glow-hover transition-all duration-300">
          <div class="w-14 h-14 bg-primary rounded-lg flex items-center justify-center mb-6 shadow-lg shadow-primary/30 group-hover:scale-110 transition-transform">
            <span class="material-icons text-navy text-3xl">electric_car</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Bornes de Recharge</h3>
          <p class="text-gray-300 text-sm mb-4">Installation certifiée de bornes de recharge pour véhicules électriques à domicile.</p>
          <a href="/services" class="text-accent-blue text-sm font-bold flex items-center gap-1 group-hover:translate-x-2 transition-transform">En savoir plus <span class="material-icons text-xs">arrow_forward_ios</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Avis Clients & FAQ -->
  <section class="py-20 bg-bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Avis -->
        <div>
          <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Électricien Bruxelles Avis</span>
          <h2 class="text-3xl font-bold text-white mb-6">Ce Que Disent Nos Clients</h2>
          <div class="space-y-6">
            <div class="bg-white text-navy p-6 rounded-xl shadow-lg relative">
              <div class="absolute -top-3 -right-3 w-10 h-10 bg-primary rounded-full flex items-center justify-center text-navy font-bold shadow-md">
                <span class="material-icons text-sm">format_quote</span>
              </div>
              <div class="flex text-primary mb-3">
                <span class="material-icons text-sm">star</span>

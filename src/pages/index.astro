  </section>

  <!-- Services -->
  <section class="py-20 bg-bg-dark bg-pattern">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12">
        <div>
          <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Nos Expertises</span>

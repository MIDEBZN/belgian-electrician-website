          </div>
          <div class="text-4xl font-extrabold text-primary mb-2">&lt;45<span class="text-lg">min</span></div>
          <p class="text-gray-300 text-sm font-medium">Temps d'intervention moyen</p>
          <p class="text-gray-500 text-xs mt-1">Pour les urgences à Bruxelles</p>
        </div>
        <div class="bg-navy-light rounded-2xl p-8 border border-white/10 text-center group hover:border-primary/30 transition-colors">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
            <span class="material-icons text-3xl text-primary">trending_up</span>
          </div>
          <div class="text-4xl font-extrabold text-primary mb-2">98<span class="text-lg">%</span></div>
          <p class="text-gray-300 text-sm font-medium">Taux de résolution</p>
          <p class="text-gray-500 text-xs mt-1">Dès la première intervention</p>
        </div>
        <div class="bg-navy-light rounded-2xl p-8 border border-white/10 text-center group hover:border-primary/30 transition-colors">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
            <span class="material-icons text-3xl text-primary">thumb_up</span>
          </div>
          <div class="text-4xl font-extrabold text-primary mb-2">4.9<span class="text-lg">/5</span></div>
          <p class="text-gray-300 text-sm font-medium">Note moyenne Google</p>
          <p class="text-gray-500 text-xs mt-1">Basé sur 127 avis vérifiés</p>

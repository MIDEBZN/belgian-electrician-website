---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quel est le tarif d'un dépannage électrique à Bruxelles ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le tarif dépannage électrique Bruxelles chez Allo Electricien est de 45€/h en journée (24h/24 â€” 7j/7) + 30€ de déplacement. Soirée et samedi : 75€/h + 40€. Nuit, dimanche et jours fériés : 95€/h + 50€. Devis clair avant toute intervention, sans frais cachés." }
    },
    {
      "@type": "Question",
      "name": "Un électricien peut-il intervenir la nuit ou le dimanche à Bruxelles ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, Allo Electricien propose un service d'électricien urgent Bruxelles nuit, dimanche et jours fériés. Notre équipe d'électriciens 24h/24 Bruxelles est disponible 365 jours par an. Appelez le 0465 73 23 48 pour une intervention électrique urgente Bruxelles à toute heure." }
    },
    {
      "@type": "Question",
      "name": "Que faire en cas de coupure de courant dans ma maison à Bruxelles ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Si vous n'avez plus d'électricité maison Bruxelles : 1) Vérifiez le disjoncteur principal et les fusibles. 2) Vérifiez si vos voisins sont touchés (panne réseau Sibelga). 3) Si la panne est isolée, appelez Allo Electricien au 0465 73 23 48 pour un dépannage coupure de courant Bruxelles rapide en moins de 45 minutes." }
    },
    {
      "@type": "Question",
      "name": "Combien de temps dure un dépannage électrique ?",
      "acceptedAnswer": { "@type": "Answer", "text": "La plupart des dépannages sont résolus en 1 à 2 heures. Pannes simples (panne disjoncteur Bruxelles, prise défectueuse) : environ 45 min. Court-circuit Bruxelles dépannage ou recherche de défaut : jusqu'à 3 heures. Notre électricien rapide Bruxelles vous donne une estimation précise sur place." }
    },
    {
      "@type": "Question",
      "name": "Intervenez-vous les jours fériés à Bruxelles ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, notre service d'électricien jour férié Bruxelles fonctionne 365 jours par an. Noël, Nouvel An, 21 juillet — nous sommes toujours disponibles pour un SOS électricien Bruxelles. Le tarif est identique à celui du dimanche : 95€/h + 50€ de déplacement." }
    },
    {
      "@type": "Question",
      "name": "Quelles pannes électriques dépannez-vous en urgence ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Nous intervenons pour tout type de panne électrique Bruxelles : coupure de courant totale ou partielle, court-circuit, disjoncteur qui saute, odeur de brûlé, étincelles, prise ou interrupteur défectueux, dépannage tableau électrique Bruxelles, dégât des eaux électrique, surcharge électrique." }
    },
    {
      "@type": "Question",
      "name": "Dans quelles communes de Bruxelles intervenez-vous ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Allo Electricien intervient dans les 19 communes de Bruxelles-Capitale : Bruxelles-Ville, Ixelles, Uccle, Schaerbeek, Anderlecht, Etterbeek, Saint-Gilles, Forest, Watermael-Boitsfort, Woluwe-Saint-Lambert, Woluwe-Saint-Pierre, Auderghem, Jette, Evere, Koekelberg, Molenbeek, Ganshoren, Berchem-Sainte-Agathe, Saint-Josse-ten-Noode, ainsi que la périphérie." }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il un supplément pour une intervention le week-end ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Notre service d'électricien week-end Bruxelles applique un tarif soirée/samedi de 75€/h + 40€ de déplacement. Le dimanche, le tarif est de 95€/h + 50€. Ces tarifs sont fixes et annoncés avant toute intervention — pas de surprise." }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Dépannage Électrique Urgent",
  "provider": { "@type": "Electrician", "name": "Allo Electricien", "telephone": "+32465732348" },
  "areaServed": { "@type": "City", "name": "Bruxelles" },
  "availableChannel": { "@type": "ServiceChannel", "servicePhone": { "@type": "ContactPoint", "telephone": "+32465732348", "contactType": "customer service", "availableLanguage": ["French", "Dutch"] } },
  "hoursAvailable": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "00:00", "closes": "23:59" },
  "offers": [
    { "@type": "Offer", "name": "Dépannage Journée", "price": "45", "priceCurrency": "EUR", "description": "Tarif horaire 24h/24 â€” 7j/7" },
    { "@type": "Offer", "name": "Dépannage Soirée/Week-end", "price": "75", "priceCurrency": "EUR", "description": "Tarif horaire soirée et week-end" },
    { "@type": "Offer", "name": "Dépannage Nuit/Dimanche/Férié", "price": "95", "priceCurrency": "EUR", "description": "Tarif horaire 22h-8h, dimanche et jours fériés" }
  ]
};
---

<Layout title="Dépannage Électrique Bruxelles — Électricien Urgence 24/7 | Allo Electricien" description="Dépannage électrique Bruxelles : électricien urgence 24h/24, 7j/7. Panne de courant, court-circuit, disjoncteur qui saute. Intervention en 45 min. ☎ 0465 73 23 48. Nuit, week-end, jours fériés." schema={faqSchema}>

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <header class="relative bg-navy overflow-hidden pt-12 pb-28 border-b border-white/5">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#4a4a8a 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute right-0 top-0 w-1/3 h-full bg-gradient-to-l from-red-500/10 to-transparent"></div>
    <div class="absolute left-0 bottom-0 w-1/4 h-1/2 bg-gradient-to-t from-primary/5 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <nav aria-label="Breadcrumb" class="flex text-sm text-gray-400 mb-6">
        <ol class="flex items-center space-x-2">
          <li><a class="hover:text-primary" href="/">Accueil</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li><a class="hover:text-primary" href="/services">Services</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li class="text-primary font-medium">Dépannage Électrique</li>
        </ol>
      </nav>
      <div class="inline-flex items-center gap-2 bg-red-600/20 border border-red-500/30 text-red-400 text-sm font-bold px-4 py-2 rounded-full mb-6 animate-pulse">
        <span class="material-icons text-base">emergency</span>URGENCE 24H/24 — ÉLECTRICIEN DISPONIBLE MAINTENANT
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 tracking-tight">
        Dépannage <span class="text-primary">Électrique</span> Bruxelles
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mt-4 leading-relaxed">
        <strong class="text-white">Électricien urgence Bruxelles</strong> — Intervention en moins de 45 minutes, 24h/24 et 7j/7 dans les 19 communes. Pannes de courant, courts-circuits, disjoncteurs, tableaux électriques.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mt-8">
        <a href="tel:+32465732348" class="flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-navy font-bold px-8 py-4 rounded-xl transition-all hover:-translate-y-1 shadow-lg shadow-primary/20 text-lg">
          <span class="material-icons text-2xl">call</span>0465 73 23 48
        </a>
        <a href="https://wa.me/32465732348" class="flex items-center justify-center gap-2 bg-green-600 hover:bg-green-500 text-white font-semibold px-8 py-4 rounded-xl transition-all hover:-translate-y-1">
          <span class="material-icons">chat</span>WhatsApp Urgence
        </a>
        <a href="/contact" class="flex items-center justify-center gap-2 bg-transparent border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all">
          <span class="material-icons">description</span>Devis Gratuit
        </a>
      </div>
    </div>
  </header>

  <main class="relative z-20 -mt-14 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">

    <!-- KEY STATS -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-primary/30 transition-colors">
        <span class="material-icons text-primary text-3xl mb-2">schedule</span>
        <p class="text-3xl font-bold text-primary">45 min</p>
        <p class="text-gray-400 text-sm mt-1">Temps d'arrivée moyen</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-primary/30 transition-colors">
        <span class="material-icons text-primary text-3xl mb-2">access_time</span>
        <p class="text-3xl font-bold text-primary">24/7</p>
        <p class="text-gray-400 text-sm mt-1">Nuit, week-end, fériés</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-primary/30 transition-colors">
        <span class="material-icons text-primary text-3xl mb-2">verified</span>
        <p class="text-3xl font-bold text-primary">2 ans</p>
        <p class="text-gray-400 text-sm mt-1">Garantie travaux</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-primary/30 transition-colors">
        <span class="material-icons text-primary text-3xl mb-2">star</span>
        <p class="text-3xl font-bold text-primary">4.9/5</p>
        <p class="text-gray-400 text-sm mt-1">Note Google (127 avis)</p>
      </div>
    </div>

    <!-- SECTION 1: WHAT'S INCLUDED -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Service Complet</span>
        <h2 class="text-3xl font-bold text-white mb-4">Ce Que Comprend Notre Dépannage Électrique à Bruxelles</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <span class="material-icons text-primary text-3xl mb-4">search</span>
          <h3 class="text-lg font-bold text-white mb-2">Diagnostic Complet</h3>
          <p class="text-gray-400 text-sm">Analyse approfondie de votre installation avec appareils de mesure professionnels. Identification précise de la cause de la panne avant toute intervention.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <span class="material-icons text-primary text-3xl mb-4">build</span>
          <h3 class="text-lg font-bold text-white mb-2">Réparation Sur Place</h3>
          <p class="text-gray-400 text-sm">Nos véhicules atelier contiennent tout le matériel nécessaire : câbles, disjoncteurs, différentiels, prises, interrupteurs. 90% des pannes résolues en une seule visite.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <span class="material-icons text-primary text-3xl mb-4">security</span>
          <h3 class="text-lg font-bold text-white mb-2">Mise en Sécurité</h3>
          <p class="text-gray-400 text-sm">Sécurisation immédiate de l'installation en cas de danger : isolation du circuit défectueux, coupure du courant dans la zone à risque, protection contre l'électrocution.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <span class="material-icons text-primary text-3xl mb-4">description</span>
          <h3 class="text-lg font-bold text-white mb-2">Devis Transparent</h3>
          <p class="text-gray-400 text-sm">Prix annoncé avant le début des travaux. Aucun frais caché, aucune surprise sur la facture. Vous validez le montant avant que nous commencions.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <span class="material-icons text-primary text-3xl mb-4">receipt_long</span>
          <h3 class="text-lg font-bold text-white mb-2">Attestation TVA 6%</h3>
          <p class="text-gray-400 text-sm">Pour les logements de plus de 10 ans, bénéficiez du taux réduit de TVA à 6% au lieu de 21%. Nous préparons l'attestation pour vous.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <span class="material-icons text-primary text-3xl mb-4">shield</span>
          <h3 class="text-lg font-bold text-white mb-2">Garantie 2 Ans</h3>
          <p class="text-gray-400 text-sm">Tous nos travaux de dépannage sont garantis 2 ans pièces et main-d'œuvre. En cas de récidive du même problème, nous revenons gratuitement.</p>
        </div>
      </div>
    </section>

    <!-- SECTION 2: COMMON PROBLEMS -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Nos Interventions</span>
        <h2 class="text-3xl font-bold text-white mb-4">Pannes Électriques Que Nous Résolvons à Bruxelles</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-red-400 text-2xl">power_off</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Coupure de Courant Totale</h3>
            <p class="text-gray-400 text-sm">Plus d'électricité dans votre maison à Bruxelles ? Nous diagnostiquons rapidement si la panne vient de votre installation ou du réseau Sibelga, et rétablissons le courant.</p>
            <p class="text-primary text-xs mt-2 font-semibold">⏱ Résolu en ~45 min</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-orange-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-orange-400 text-2xl">flash_on</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Court-Circuit</h3>
            <p class="text-gray-400 text-sm">Court-circuit Bruxelles dépannage : localisation précise du défaut avec appareils de mesure, isolation du circuit endommagé et réparation définitive du câblage.</p>
            <p class="text-primary text-xs mt-2 font-semibold">⏱ Résolu en 1-2h</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-yellow-400 text-2xl">toggle_off</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Disjoncteur Qui Saute</h3>
            <p class="text-gray-400 text-sm">Panne disjoncteur Bruxelles : surcharge, défaut d'isolement, appareil défectueux ? Nous identifions la cause exacte et corrigeons le problème pour éviter toute récidive.</p>
            <p class="text-primary text-xs mt-2 font-semibold">⏱ Résolu en ~45 min</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-red-400 text-2xl">local_fire_department</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Odeur de Brûlé / Étincelles</h3>
            <p class="text-gray-400 text-sm">SOS électricien Bruxelles pour situation dangereuse : mise en sécurité immédiate, identification de la source (câble fondu, connexion oxydée) et réparation d'urgence.</p>
            <p class="text-primary text-xs mt-2 font-semibold">⏱ Intervention immédiate</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-blue-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-blue-400 text-2xl">settings_input_component</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Tableau Électrique Défaillant</h3>
            <p class="text-gray-400 text-sm">Dépannage tableau électrique Bruxelles : remplacement de disjoncteurs grillés, ajout de différentiels 30mA, remise en service après coupure. <a href="/services/tableau-electrique" class="text-primary hover:underline">En savoir plus →</a></p>
            <p class="text-primary text-xs mt-2 font-semibold">⏱ Résolu en 1-2h</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-cyan-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-cyan-400 text-2xl">water_damage</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Dégât des Eaux Électrique</h3>
            <p class="text-gray-400 text-sm">Infiltration d'eau dans votre installation ? Intervention électrique urgente Bruxelles : coupure sécurisée, séchage, test d'isolation et remise sous tension circuit par circuit.</p>
            <p class="text-primary text-xs mt-2 font-semibold">⏱ Résolu en 2-3h</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-purple-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-purple-400 text-2xl">electrical_services</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Prise / Interrupteur HS</h3>
            <p class="text-gray-400 text-sm">Prise qui chauffe, interrupteur qui grésille, raccordement défectueux ? Remplacement rapide avec du matériel aux normes RGIE et test de sécurité.</p>
            <p class="text-primary text-xs mt-2 font-semibold">⏱ Résolu en ~30 min</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-green-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-green-400 text-2xl">bolt</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Surcharge Électrique</h3>
            <p class="text-gray-400 text-sm">Câblage sous-dimensionné, trop d'appareils sur un circuit ? Nous rééquilibrons vos circuits et ajoutons des lignes dédiées si nécessaire pour un fonctionnement sûr.</p>
            <p class="text-primary text-xs mt-2 font-semibold">⏱ Résolu en 1-3h</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: OUR PROCESS -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Étape par Étape</span>
        <h2 class="text-3xl font-bold text-white mb-4">Notre Processus de Dépannage Électricité Bruxelles</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="relative">
        <div class="hidden md:block absolute top-1/2 left-0 w-full h-0.5 -translate-y-1/2 z-0 border-t-2 border-dotted border-gray-600"></div>
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6 relative z-10">
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-primary rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-primary font-bold text-xl">1</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Votre Appel</h3>
            <p class="text-gray-400 text-sm">Appelez le <strong class="text-white">0465 73 23 48</strong>. Décrivez votre panne à notre opérateur. Disponible 24h/24, même la nuit et le dimanche.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-primary rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-primary font-bold text-xl">2</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Dispatch Immédiat</h3>
            <p class="text-gray-400 text-sm">L'électricien rapide Bruxelles le plus proche est envoyé chez vous. Temps d'arrivée moyen : <strong class="text-white">45 minutes</strong>.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-primary rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-primary font-bold text-xl">3</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Diagnostic</h3>
            <p class="text-gray-400 text-sm">Sur place, diagnostic complet avec appareils de mesure professionnels. Vous recevez un devis clair <strong class="text-white">avant toute réparation</strong>.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-primary rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-primary font-bold text-xl">4</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Réparation</h3>
            <p class="text-gray-400 text-sm">Intervention avec matériel professionnel embarqué. <strong class="text-white">90% des pannes résolues en une visite</strong>. Pièces de rechange incluses.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-primary rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-primary font-bold text-xl">5</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Test & Garantie</h3>
            <p class="text-gray-400 text-sm">Vérification complète de l'installation, rapport d'intervention et <strong class="text-white">garantie 2 ans</strong> sur les travaux effectués.</p>

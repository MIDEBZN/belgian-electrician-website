---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien coûte une installation domotique à Bruxelles ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le prix d'une installation domotique Bruxelles varie selon l'ampleur du projet. Pack éclairage intelligent : 500€ à 1 500€. Pack confort (éclairage + chauffage + volets) : 2 000€ à 5 000€. Maison complète (KNX/Loxone) : 5 000€ à 15 000€+. Consultation et devis gratuit chez Allo Electricien." }
    },
    {
      "@type": "Question",
      "name": "Peut-on domotiser une maison ancienne sans gros travaux ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui ! Les solutions sans fil (Zigbee, Z-Wave, WiFi) permettent de rendre une maison ancienne intelligente sans casser les murs. Interrupteurs connectés, prises intelligentes, thermostats WiFi : tout se pose en remplacement de l'existant. Allo Electricien adapte chaque installation domotique Bruxelles au type de logement." }
    },
    {
      "@type": "Question",
      "name": "Quelle est la différence entre KNX, Loxone et Niko Home Control ?",
      "acceptedAnswer": { "@type": "Answer", "text": "KNX est le standard industriel câblé, ultra-fiable, idéal pour les constructions neuves et les grands projets. Loxone est une solution intégrée tout-en-un avec serveur dédié. Niko Home Control est la solution belge, simple et efficace, compatible avec l'écosystème Niko. Allo Electricien installe et programme les trois systèmes." }
    },
    {
      "@type": "Question",
      "name": "La domotique permet-elle de faire des économies d'énergie ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, une installation domotique bien configurée permet d'économiser 20% à 35% sur la facture d'énergie. Chauffage intelligent par zones, extinction automatique des lumières, gestion des volets selon le soleil, suivi de consommation en temps réel : chaque automatisation contribue aux économies." }
    },
    {
      "@type": "Question",
      "name": "Puis-je contrôler ma maison à distance avec la domotique ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, toutes nos installations incluent le pilotage à distance via smartphone (iOS et Android). Vous pouvez contrôler l'éclairage, le chauffage, les volets, la sécurité et visualiser vos caméras depuis n'importe où dans le monde via une application sécurisée." }
    },
    {
      "@type": "Question",
      "name": "La domotique est-elle compatible avec les assistants vocaux ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui ! Nos installations sont compatibles avec Apple HomeKit/Siri, Google Home/Assistant et Amazon Alexa. Contrôlez votre maison à la voix : 'Ok Google, éteins les lumières du salon', 'Alexa, ferme les volets'. Nous configurons l'intégration complète." }
    },
    {
      "@type": "Question",
      "name": "Combien de temps dure l'installation domotique ?",
      "acceptedAnswer": { "@type": "Answer", "text": "L'installation domotique Bruxelles varie selon le projet. Éclairage connecté : 1 journée. Pack confort complet : 2-3 jours. Maison complète KNX/Loxone : 3-5 jours. La programmation des scénarios et l'optimisation sont incluses." }
    },
    {
      "@type": "Question",
      "name": "Que se passe-t-il en cas de panne Internet ou de courant ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Les systèmes professionnels (KNX, Loxone, Niko) fonctionnent localement, sans Internet. En cas de coupure Internet, votre domotique continue de fonctionner normalement — seul le pilotage à distance est temporairement indisponible. Après une coupure de courant, le système redémarre automatiquement." }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Installation Domotique et Maison Intelligente",
  "provider": { "@type": "Electrician", "name": "Allo Electricien", "telephone": "+32465732348" },
  "areaServed": { "@type": "City", "name": "Bruxelles" },
  "offers": [
    { "@type": "Offer", "name": "Pack Éclairage Intelligent", "price": "500", "priceCurrency": "EUR", "description": "Éclairage connecté, à partir de 500€" },
    { "@type": "Offer", "name": "Pack Confort", "price": "2000", "priceCurrency": "EUR", "description": "Éclairage + chauffage + volets, à partir de 2 000€" },
    { "@type": "Offer", "name": "Maison Complète", "price": "5000", "priceCurrency": "EUR", "description": "Système intégral KNX/Loxone, à partir de 5 000€" }
  ]
};
---

<Layout title="Installation Domotique Bruxelles — Maison Intelligente & Connectée | Allo Electricien" description="Installation domotique Bruxelles : maison intelligente sur mesure. KNX, Loxone, Niko Home Control. Éclairage, chauffage, volets, sécurité. Devis gratuit. ☎ 0465 73 23 48. Économisez 20-35% d'énergie." schema={faqSchema}>

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <header class="relative bg-navy overflow-hidden pt-12 pb-28 border-b border-white/5">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#4a4a8a 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute right-0 top-0 w-1/3 h-full bg-gradient-to-l from-purple-500/5 to-transparent"></div>
    <div class="absolute left-0 bottom-0 w-1/4 h-1/2 bg-gradient-to-t from-primary/5 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <nav aria-label="Breadcrumb" class="flex text-sm text-gray-400 mb-6">
        <ol class="flex items-center space-x-2">
          <li><a class="hover:text-primary" href="/">Accueil</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li><a class="hover:text-primary" href="/services">Services</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li class="text-primary font-medium">Domotique</li>
        </ol>
      </nav>
      <div class="inline-flex items-center gap-2 bg-purple-500/20 border border-purple-500/30 text-purple-400 text-sm font-bold px-4 py-2 rounded-full mb-6">
        <span class="material-icons text-base">touch_app</span>MAISON INTELLIGENTE — SUR MESURE
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 tracking-tight">
        Installation <span class="text-primary">Domotique</span> Bruxelles
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mt-4 leading-relaxed">
        <strong class="text-white">Installation domotique Bruxelles</strong> sur mesure : éclairage intelligent, chauffage connecté, volets automatisés, sécurité, commande vocale. KNX, Loxone, Niko Home Control. Devis gratuit.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mt-8">
        <a href="/contact" class="flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-navy font-bold px-8 py-4 rounded-xl transition-all hover:-translate-y-1 shadow-lg shadow-primary/20 text-lg">
          <span class="material-icons text-2xl">description</span>Consultation Gratuite
        </a>
        <a href="tel:+32465732348" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-xl border border-white/20 transition-all hover:-translate-y-1">
          <span class="material-icons">call</span>0465 73 23 48
        </a>
        <a href="https://wa.me/32465732348" class="flex items-center justify-center gap-2 bg-green-600 hover:bg-green-500 text-white font-semibold px-8 py-4 rounded-xl transition-all hover:-translate-y-1">
          <span class="material-icons">chat</span>WhatsApp
        </a>
      </div>
    </div>
  </header>

  <main class="relative z-20 -mt-14 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">

    <!-- KEY STATS -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-purple-500/30 transition-colors">
        <span class="material-icons text-purple-400 text-3xl mb-2">energy_savings_leaf</span>
        <p class="text-3xl font-bold text-purple-400">-35%</p>
        <p class="text-gray-400 text-sm mt-1">Économies d'énergie</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-purple-500/30 transition-colors">
        <span class="material-icons text-purple-400 text-3xl mb-2">phone_iphone</span>
        <p class="text-3xl font-bold text-purple-400">24/7</p>
        <p class="text-gray-400 text-sm mt-1">Contrôle à distance</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-primary/30 transition-colors">
        <span class="material-icons text-primary text-3xl mb-2">record_voice_over</span>
        <p class="text-3xl font-bold text-primary">Vocal</p>
        <p class="text-gray-400 text-sm mt-1">Siri, Google, Alexa</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-primary/30 transition-colors">
        <span class="material-icons text-primary text-3xl mb-2">trending_up</span>
        <p class="text-3xl font-bold text-primary">+10%</p>
        <p class="text-gray-400 text-sm mt-1">Plus-value immobilière</p>
      </div>
    </div>

    <!-- SECTION 1: WHAT'S INCLUDED -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Service Complet</span>
        <h2 class="text-3xl font-bold text-white mb-4">Ce Que Comprend Notre Installation Domotique Bruxelles</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">lightbulb</span>
          <h3 class="text-lg font-bold text-white mb-2">Éclairage Intelligent</h3>
          <p class="text-gray-400 text-sm">Interrupteurs connectés, variateurs, scénarios lumineux (lecture, cinéma, dîner), détection de présence, programmation horaire. Philips Hue, Niko, DALI.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">thermostat</span>
          <h3 class="text-lg font-bold text-white mb-2">Chauffage Connecté</h3>
          <p class="text-gray-400 text-sm">Thermostat intelligent par zone, programmation hebdomadaire, géolocalisation (chauffe avant votre arrivée), suivi de consommation en temps réel. Tado, Nest, Netatmo.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">blinds</span>
          <h3 class="text-lg font-bold text-white mb-2">Volets & Stores Automatisés</h3>
          <p class="text-gray-400 text-sm">Motorisation des volets roulants et stores, fermeture automatique au coucher du soleil, ouverture selon météo, intégration dans les scénarios. Somfy, Velux.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">security</span>
          <h3 class="text-lg font-bold text-white mb-2">Sécurité & Alarme</h3>
          <p class="text-gray-400 text-sm">Alarme connectée, caméras IP, détecteurs de mouvement/ouverture, simulation de présence (lumières aléatoires pendant les vacances), alertes smartphone temps réel.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">record_voice_over</span>
          <h3 class="text-lg font-bold text-white mb-2">Commande Vocale</h3>
          <p class="text-gray-400 text-sm">Intégration Apple Siri, Google Assistant et Amazon Alexa. Contrôlez votre maison à la voix : « Ok Google, éteins tout » ou « Alexa, lance le scénario cinéma ».</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">music_note</span>
          <h3 class="text-lg font-bold text-white mb-2">Audio Multi-Room</h3>
          <p class="text-gray-400 text-sm">Son distribué dans toute la maison via Sonos, Loxone Audio ou systèmes encastrés. Musique dans chaque pièce, volume indépendant, synchronisation multi-zone.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">videocam</span>
          <h3 class="text-lg font-bold text-white mb-2">Vidéophonie Connectée</h3>
          <p class="text-gray-400 text-sm">Interphone vidéo connecté au smartphone. Voyez et parlez à vos visiteurs à distance. Ouverture de porte depuis l'application, historique des visites.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">energy_savings_leaf</span>
          <h3 class="text-lg font-bold text-white mb-2">Gestion Énergie</h3>
          <p class="text-gray-400 text-sm">Suivi de consommation en temps réel, gestion des panneaux solaires, optimisation de la recharge véhicule électrique, alertes surconsommation.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <span class="material-icons text-purple-400 text-3xl mb-4">auto_awesome</span>
          <h3 class="text-lg font-bold text-white mb-2">Scénarios & Automatisations</h3>
          <p class="text-gray-400 text-sm">Création de scénarios personnalisés : « Bonjour » (volets + lumières + chauffage), « Bonne nuit » (tout éteindre), « Vacances » (simulation de présence). Illimités.</p>
        </div>
      </div>
    </section>

    <!-- SECTION 2: COMMON PROBLEMS WE SOLVE -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Solutions</span>
        <h2 class="text-3xl font-bold text-white mb-4">Les Problèmes Que la Domotique Résout</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
        <p class="text-gray-400 mt-4 max-w-2xl mx-auto">Notre <strong class="text-white">installation domotique Bruxelles</strong> apporte des solutions concrètes aux problèmes quotidiens de votre habitation.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-red-400 text-2xl">payments</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Facture d'Énergie Trop Élevée</h3>
            <p class="text-gray-400 text-sm">Le chauffage tourne quand personne n'est là ? Les lumières restent allumées ? La domotique optimise automatiquement votre consommation : <strong class="text-white">-20% à -35% sur la facture d'énergie</strong>.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : chauffage intelligent + extinction automatique</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-red-400 text-2xl">security</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Sentiment d'Insécurité</h3>
            <p class="text-gray-400 text-sm">Inquiet pendant vos absences ? La domotique simule votre présence (lumières aléatoires), envoie des alertes intrusion, et vous permet de surveiller votre maison en temps réel via caméras.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : alarme connectée + simulation de présence</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-orange-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-orange-400 text-2xl">thermostat</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Confort Thermique Insuffisant</h3>
            <p class="text-gray-400 text-sm">Certaines pièces trop chaudes, d'autres trop froides ? Le chauffage par zone avec thermostat intelligent ajuste la température pièce par pièce selon vos habitudes.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : thermostat multi-zones + géolocalisation</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-orange-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-orange-400 text-2xl">blinds_closed</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Gestion Manuelle Fastidieuse</h3>
            <p class="text-gray-400 text-sm">Fermer tous les volets un par un le soir ? Éteindre toutes les lumières ? Un seul bouton « Bonne nuit » fait tout automatiquement. Plus de routine répétitive.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : scénarios automatisés un bouton</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-yellow-400 text-2xl">elderly</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Accessibilité & Mobilité Réduite</h3>
            <p class="text-gray-400 text-sm">La domotique facilite le quotidien des personnes à mobilité réduite : commande vocale, automatisation, pas besoin de se déplacer pour allumer ou éteindre.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : commande vocale + automatisation complète</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-purple-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-yellow-400 text-2xl">water_damage</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Fuites & Dégâts des Eaux</h3>
            <p class="text-gray-400 text-sm">Détecteurs de fuite connectés qui vous alertent immédiatement sur votre smartphone et peuvent couper automatiquement l'arrivée d'eau. Prévenir les dégâts coûteux.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : capteurs de fuite + vanne automatique</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: OUR PROCESS -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Étape par Étape</span>
        <h2 class="text-3xl font-bold text-white mb-4">Notre Processus d'Installation Domotique</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="relative">
        <div class="hidden md:block absolute top-1/2 left-0 w-full h-0.5 -translate-y-1/2 z-0 border-t-2 border-dotted border-gray-600"></div>
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6 relative z-10">
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-purple-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-purple-400 font-bold text-xl">1</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Consultation Gratuite</h3>
            <p class="text-gray-400 text-xs">Discussion de vos besoins, style de vie, budget. Nous identifions les fonctionnalités les plus utiles pour vous.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-purple-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-purple-400 font-bold text-xl">2</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Visite & Diagnostic</h3>
            <p class="text-gray-400 text-xs">Visite de votre logement, analyse de l'installation existante, repérage des emplacements. Rapport technique complet.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-purple-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-purple-400 font-bold text-xl">3</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Conception & Devis</h3>
            <p class="text-gray-400 text-xs">Conception du système sur mesure. Devis détaillé avec schéma de l'<strong class="text-white">installation domotique</strong>. Sans engagement.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-purple-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-purple-400 font-bold text-xl">4</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Installation</h3>
            <p class="text-gray-400 text-xs"><strong class="text-white">Installation domotique Bruxelles</strong> : câblage, pose des équipements, programmation des scénarios et automatisations.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-purple-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-purple-400 font-bold text-xl">5</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Formation & Support</h3>
            <p class="text-gray-400 text-xs">Formation complète à l'utilisation. Configuration des apps sur vos appareils. Support technique inclus.</p>
          </div>
        </div>
      </div>
    </section>


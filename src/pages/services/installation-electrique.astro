---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien coûte une installation électrique complète à Bruxelles ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le prix d'une installation électrique Bruxelles dépend de la taille du logement et de la complexité. Studio/1 chambre : 3 000€ à 5 000€. Appartement 2-3 chambres : 5 000€ à 8 000€. Maison complète : 8 000€ à 15 000€+. Rénovation partielle : à partir de 1 500€. TVA 6% pour logements de plus de 10 ans. Devis gratuit." }
    },
    {
      "@type": "Question",
      "name": "Faut-il refaire toute l'installation électrique lors d'une rénovation ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pas toujours. Après un diagnostic complet, nous déterminons ce qui peut être conservé et ce qui doit être remplacé. Si l'installation a plus de 30 ans, un remplacement complet est souvent recommandé pour la sécurité et la conformité RGIE. Pour les installations plus récentes, une mise à jour partielle peut suffire." }
    },
    {
      "@type": "Question",
      "name": "Combien de temps dure une installation électrique complète ?",
      "acceptedAnswer": { "@type": "Answer", "text": "La durée d'une installation électrique Bruxelles varie selon le projet. Studio : 2-3 jours. Appartement : 3-5 jours. Maison : 5-10 jours. Rénovation partielle : 1-3 jours. Nous planifions soigneusement pour minimiser les perturbations." }
    },
    {
      "@type": "Question",
      "name": "L'installation sera-t-elle conforme au RGIE ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, absolument. Toute installation électrique Bruxelles réalisée par Allo Electricien est conforme au RGIE (Règlement Général sur les Installations Électriques). Nous préparons le dossier pour le contrôle par un organisme agréé (Vinçotte, AIB, BTV) et garantissons la conformité — 98% de réussite au premier passage." }
    },
    {
      "@type": "Question",
      "name": "Proposez-vous un service de dépannage après l'installation ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, Allo Electricien assure un suivi post-installation complet. Garantie 2 ans sur la main-d'œuvre, dépannage prioritaire 24/7 pour nos clients, et assistance technique par téléphone. En cas de problème, nous intervenons en priorité." }
    },
    {
      "@type": "Question",
      "name": "Pouvez-vous installer des prises et interrupteurs design ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui ! Nous travaillons avec les marques premium : Niko (marque belge), Legrand, Schneider, Bticino, Gira. Du classique blanc au design moderne en verre, aluminium ou bois. Nous vous conseillons sur les finitions adaptées à votre intérieur." }
    },
    {
      "@type": "Question",
      "name": "L'installation inclut-elle le tableau électrique ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, une installation électrique complète inclut toujours le tableau électrique avec tous les disjoncteurs, différentiels et protections nécessaires. Nous dimensionnons le tableau en fonction de vos besoins actuels et futurs (borne de recharge, domotique, etc.)." }
    },
    {
      "@type": "Question",
      "name": "Peut-on prévoir la domotique dans une nouvelle installation ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, c'est même le moment idéal ! Lors d'une nouvelle installation électrique, nous pouvons prévoir le précâblage pour la domotique (KNX, Loxone, Niko Home Control) à moindre coût. Cela évite de devoir tout refaire plus tard." }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Installation Électrique Résidentielle et Commerciale",
  "provider": { "@type": "Electrician", "name": "Allo Electricien", "telephone": "+32465732348" },
  "areaServed": { "@type": "City", "name": "Bruxelles" },
  "offers": [
    { "@type": "Offer", "name": "Rénovation Partielle", "price": "1500", "priceCurrency": "EUR", "description": "Rénovation électrique partielle, à partir de 1 500€" },
    { "@type": "Offer", "name": "Appartement Complet", "price": "5000", "priceCurrency": "EUR", "description": "Installation complète appartement, à partir de 5 000€" },
    { "@type": "Offer", "name": "Maison Complète", "price": "8000", "priceCurrency": "EUR", "description": "Installation complète maison, à partir de 8 000€" }
  ]
};
---

<Layout title="Installation Électrique Bruxelles — Neuf & Rénovation | Allo Electricien" description="Installation électrique Bruxelles : neuf, rénovation, extension. Câblage structuré, prises, interrupteurs, tableau, éclairage LED. Conformité RGIE garantie. Devis gratuit. ☎ 0465 73 23 48" schema={faqSchema}>

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <header class="relative bg-navy overflow-hidden pt-12 pb-28 border-b border-white/5">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#4a4a8a 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute right-0 top-0 w-1/3 h-full bg-gradient-to-l from-amber-500/5 to-transparent"></div>
    <div class="absolute left-0 bottom-0 w-1/4 h-1/2 bg-gradient-to-t from-primary/5 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <nav aria-label="Breadcrumb" class="flex text-sm text-gray-400 mb-6">
        <ol class="flex items-center space-x-2">
          <li><a class="hover:text-primary" href="/">Accueil</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li><a class="hover:text-primary" href="/services">Services</a></li>
          <li><span class="text-gray-600">/</span></li>
          <li class="text-primary font-medium">Installation Électrique</li>
        </ol>
      </nav>
      <div class="inline-flex items-center gap-2 bg-amber-500/20 border border-amber-500/30 text-amber-400 text-sm font-bold px-4 py-2 rounded-full mb-6">
        <span class="material-icons text-base">home</span>NEUF • RÉNOVATION • EXTENSION
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 tracking-tight">
        Installation <span class="text-primary">Électrique</span> Bruxelles
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mt-4 leading-relaxed">
        <strong class="text-white">Installation électrique Bruxelles</strong> complète pour nouvelles constructions, rénovations et extensions. Câblage structuré, prises, interrupteurs, tableau, éclairage LED. Conformité RGIE garantie.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mt-8">
        <a href="/contact" class="flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-navy font-bold px-8 py-4 rounded-xl transition-all hover:-translate-y-1 shadow-lg shadow-primary/20 text-lg">
          <span class="material-icons text-2xl">description</span>Devis Gratuit
        </a>
        <a href="tel:+32465732348" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-xl border border-white/20 transition-all hover:-translate-y-1">
          <span class="material-icons">call</span>0465 73 23 48
        </a>
        <a href="https://wa.me/32465732348" class="flex items-center justify-center gap-2 bg-green-600 hover:bg-green-500 text-white font-semibold px-8 py-4 rounded-xl transition-all hover:-translate-y-1">
          <span class="material-icons">chat</span>WhatsApp
        </a>
      </div>
    </div>
  </header>

  <main class="relative z-20 -mt-14 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">

    <!-- KEY STATS -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-amber-500/30 transition-colors">
        <span class="material-icons text-amber-400 text-3xl mb-2">verified</span>
        <p class="text-3xl font-bold text-amber-400">RGIE</p>
        <p class="text-gray-400 text-sm mt-1">Conformité garantie</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-amber-500/30 transition-colors">
        <span class="material-icons text-amber-400 text-3xl mb-2">percent</span>
        <p class="text-3xl font-bold text-amber-400">98%</p>
        <p class="text-gray-400 text-sm mt-1">Réussite contrôle</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-primary/30 transition-colors">
        <span class="material-icons text-primary text-3xl mb-2">workspace_premium</span>
        <p class="text-3xl font-bold text-primary">2 ans</p>
        <p class="text-gray-400 text-sm mt-1">Garantie main-d'œuvre</p>
      </div>
      <div class="bg-navy rounded-xl border border-white/10 p-6 text-center shadow-xl hover:border-primary/30 transition-colors">
        <span class="material-icons text-primary text-3xl mb-2">savings</span>
        <p class="text-3xl font-bold text-primary">TVA 6%</p>
        <p class="text-gray-400 text-sm mt-1">Logements +10 ans</p>
      </div>
    </div>

    <!-- SECTION 1: WHAT'S INCLUDED -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Service Complet</span>
        <h2 class="text-3xl font-bold text-white mb-4">Ce Que Comprend Notre Installation Électrique Bruxelles</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">cable</span>
          <h3 class="text-lg font-bold text-white mb-2">Câblage Structuré Complet</h3>
          <p class="text-gray-400 text-sm">Câblage en cuivre de qualité professionnelle (XVB, VOB). Passage en gaines encastrées ou apparentes. Respect des sections normatives selon le RGIE.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">power</span>
          <h3 class="text-lg font-bold text-white mb-2">Prises & Interrupteurs</h3>
          <p class="text-gray-400 text-sm">Pose de prises de courant, prises USB, interrupteurs simples/double allumage/va-et-vient. Marques premium : Niko, Legrand, Schneider, Bticino.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">settings_input_component</span>
          <h3 class="text-lg font-bold text-white mb-2">Tableau Électrique</h3>
          <p class="text-gray-400 text-sm">Installation ou remplacement du tableau de distribution. Disjoncteurs, différentiels 30mA type A/AC, répartition des circuits optimisée. Dimensionné pour l'avenir.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">lightbulb</span>
          <h3 class="text-lg font-bold text-white mb-2">Éclairage LED</h3>
          <p class="text-gray-400 text-sm">Points lumineux, spots encastrés, rubans LED, appliques, suspensions. Variateurs et détecteurs de présence pour les économies d'énergie.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">grounding</span>
          <h3 class="text-lg font-bold text-white mb-2">Mise à la Terre</h3>
          <p class="text-gray-400 text-sm">Installation ou vérification de la prise de terre. Liaison équipotentielle salle de bain. Mesure de résistance de terre. Indispensable pour la sécurité.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">router</span>
          <h3 class="text-lg font-bold text-white mb-2">Réseau Data & Multimédia</h3>
          <p class="text-gray-400 text-sm">Câblage réseau RJ45 Cat.6, prises TV/SAT, pré-câblage fibre optique. Coffret de communication pour centraliser vos connexions.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">ev_station</span>
          <h3 class="text-lg font-bold text-white mb-2">Pré-câblage Spécialisé</h3>
          <p class="text-gray-400 text-sm">Pré-câblage pour borne de recharge, climatisation, panneaux solaires, domotique (KNX/Loxone). Anticipez vos besoins futurs à moindre coût.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">description</span>
          <h3 class="text-lg font-bold text-white mb-2">Schéma Unifilaire & Dossier</h3>
          <p class="text-gray-400 text-sm">Réalisation du schéma unifilaire et du plan de position obligatoires. Dossier complet prêt pour le contrôle par organisme agréé.</p>
        </div>
        <div class="bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <span class="material-icons text-amber-400 text-3xl mb-4">fact_check</span>
          <h3 class="text-lg font-bold text-white mb-2">Contrôle & Attestation</h3>
          <p class="text-gray-400 text-sm">Préparation et accompagnement pour le contrôle RGIE (Vinçotte, AIB, BTV). Attestation de conformité délivrée. 98% de réussite au premier passage.</p>
        </div>
      </div>
    </section>

    <!-- SECTION 2: COMMON PROBLEMS WE SOLVE -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Situations</span>
        <h2 class="text-3xl font-bold text-white mb-4">Quand Faut-il une Nouvelle Installation Électrique ?</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
        <p class="text-gray-400 mt-4 max-w-2xl mx-auto">Notre service d'<strong class="text-white">installation électrique Bruxelles</strong> répond à toutes les situations nécessitant une installation neuve ou une rénovation complète.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-amber-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-amber-400 text-2xl">construction</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Nouvelle Construction</h3>
            <p class="text-gray-400 text-sm">Construction neuve ou extension ? Nous concevons et réalisons l'<strong class="text-white">installation électrique complète</strong> : du compteur au dernier interrupteur, en passant par le tableau et tous les circuits.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : installation complète clé en main</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-amber-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-amber-400 text-2xl">home_repair_service</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Rénovation Complète</h3>
            <p class="text-gray-400 text-sm">Vous rénovez votre maison ou appartement ? C'est le moment idéal pour refaire l'installation électrique. Remplacement complet du câblage, du tableau et de tous les points.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : rénovation électrique totale + conformité RGIE</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-red-400 text-2xl">warning</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Installation Vétuste (+30 ans)</h3>
            <p class="text-gray-400 text-sm">Câblage en aluminium, fusibles anciens, absence de différentiel, prises sans terre — une installation de plus de 30 ans présente des <strong class="text-white">risques d'incendie et d'électrocution</strong>.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : remplacement complet aux normes actuelles</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-red-400 text-2xl">do_not_disturb</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Contrôle RGIE Refusé</h3>
            <p class="text-gray-400 text-sm">Votre installation a échoué au contrôle périodique ? Non-conformités sévères détectées ? Nous corrigeons toutes les infractions et préparons le recontrôle.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : mise en conformité + nouveau contrôle</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-orange-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-orange-400 text-2xl">electrical_services</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Manque de Prises / Circuits</h3>
            <p class="text-gray-400 text-sm">Multiprises partout ? Disjoncteur qui saute régulièrement ? Votre installation n'est plus adaptée à vos besoins modernes (appareils, cuisine équipée, bureau).</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : extension & ajout de circuits dédiés</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-navy rounded-xl border border-white/10 p-6 hover:border-amber-500/30 transition-colors">
          <div class="w-12 h-12 rounded-full bg-orange-500/10 flex items-center justify-center flex-shrink-0">
            <span class="material-icons text-orange-400 text-2xl">real_estate_agent</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-1">Vente / Achat Immobilier</h3>
            <p class="text-gray-400 text-sm">Mise en vente ou achat d'un bien ? Le contrôle électrique est obligatoire. Si l'installation est non conforme, nous la rénovons avant la transaction.</p>
            <p class="text-green-400 text-xs mt-2 font-semibold">✓ Solution : mise aux normes avant vente/achat</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: OUR PROCESS -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Étape par Étape</span>
        <h2 class="text-3xl font-bold text-white mb-4">Notre Processus d'Installation Électrique</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="relative">
        <div class="hidden md:block absolute top-1/2 left-0 w-full h-0.5 -translate-y-1/2 z-0 border-t-2 border-dotted border-gray-600"></div>
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6 relative z-10">
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-amber-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-amber-400 font-bold text-xl">1</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Visite & Diagnostic</h3>
            <p class="text-gray-400 text-xs">Visite gratuite sur place. Analyse de vos besoins, relevé des mesures, étude de l'existant. Plan de l'installation proposé.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-amber-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-amber-400 font-bold text-xl">2</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Devis Détaillé</h3>
            <p class="text-gray-400 text-xs">Devis complet avec plan de position, nombre de points, choix des finitions. Prix <strong class="text-white">installation électrique Bruxelles</strong> tout compris.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-amber-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-amber-400 font-bold text-xl">3</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Installation</h3>
            <p class="text-gray-400 text-xs">Passage des câbles, pose du tableau, raccordement des circuits, installation des prises et interrupteurs. Travail soigné et propre.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-amber-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-amber-400 font-bold text-xl">4</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Tests & Schémas</h3>
            <p class="text-gray-400 text-xs">Tests de chaque circuit, mesure d'isolement, vérification des différentiels. Réalisation du schéma unifilaire et plan de position.</p>
          </div>
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 bg-navy border-2 border-amber-400 rounded-full flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform">
              <span class="text-amber-400 font-bold text-xl">5</span>
            </div>
            <h3 class="text-base font-bold text-white mb-2">Contrôle RGIE</h3>
            <p class="text-gray-400 text-xs">Planification du contrôle par organisme agréé (Vinçotte, AIB, BTV). Accompagnement le jour du contrôle. Attestation de conformité.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 4: PRICING -->
    <section class="mb-16">
      <div class="text-center mb-10">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Nos Tarifs</span>

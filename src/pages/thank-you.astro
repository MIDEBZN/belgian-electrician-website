---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Merci de nous avoir contactés | Allo Electricien" description="Merci pour votre message. Nous vous répondrons dans les plus brefs délais.">
  <main class="flex-grow flex items-center justify-center min-h-[60vh] bg-bg-dark">
    <div class="text-center px-4">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-green-500/10 rounded-full mb-6">
        <span class="material-icons text-green-500 text-5xl">check_circle</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Message Envoyé !</h1>
      <p class="text-gray-300 text-lg mb-8 max-w-md mx-auto">Merci de nous avoir contactés. Votre demande a bien été reçue et nous vous répondrons dans les plus brefs délais.</p>
      <a href="/" class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-primary text-navy font-bold rounded-lg hover:bg-primary-hover transition-colors">
        <span class="material-icons">home</span>
        Retour à l'accueil
      </a>
    </div>
  </main>
</Layout>

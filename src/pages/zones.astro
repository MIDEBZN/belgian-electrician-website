---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import mapImage from '../assets/belgium-map.jpg';
import { communes } from '../data/communes';

// Sort alphabetically
const sortedCommunes = [...communes].sort((a, b) => a.name.localeCompare(b.name));
---

<Layout 
	title="Zones d'intervention - Électricien Bruxelles & Brabant"
	description="Liste des communes couvertes par Allo Electricien. Intervention rapide à Bruxelles (19 communes) et en périphérie (Waterloo, Zaventem, etc.)."
>
	<main class="bg-navy min-h-screen">
		<!-- Hero Section -->
		<div class="relative h-[40vh] min-h-[400px] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				<Image 
					src={mapImage} 
					alt="Carte intervention Belgique"
					class="w-full h-full object-cover opacity-20"
					widths={[640, 1024, 1920, mapImage.width]}
					sizes="100vw"
					quality="mid"
					loading="eager"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-navy/80 via-navy/50 to-navy"></div>
			</div>
			
			<div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
				<span class="inline-block py-1 px-3 rounded-full bg-primary/20 text-primary text-sm font-bold mb-6 border border-primary/20 backdrop-blur-sm">
					Partout à Bruxelles & Environs
				</span>
				<h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">
					Zones d'Intervention
				</h1>
				<p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
					Nos électriciens agréés interviennent dans les 19 communes de Bruxelles et la périphérie (Brabant Flamand & Wallon).
				</p>
			</div>
		</div>

		<!-- Zones Grid -->
		<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 -mt-20 relative z-20">
			<div class="bg-navy-light rounded-2xl p-8 border border-white/10 shadow-2xl backdrop-blur-xl">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{sortedCommunes.map((commune) => (
						<a href={`/electricien-${commune.slug}`} class="group block bg-navy hover:bg-white/5 border border-white/5 hover:border-primary/50 rounded-xl p-6 transition-all duration-300 hover:-translate-y-1">
							<div class="flex items-start justify-between mb-4">
								<div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-navy transition-colors">
									<span class="material-icons text-xl">location_on</span>
								</div>
								<span class="text-sm font-mono text-gray-500 bg-black/20 px-2 py-1 rounded">{commune.zip}</span>
							</div>
							<h2 class="text-xl font-bold text-white mb-2 group-hover:text-primary transition-colors">
								{commune.name}
							</h2>
							<p class="text-gray-300 text-sm line-clamp-2">
								{commune.metaDescription.replace(/^Électricien.*?(\.|$)/, '')}
							</p>
							<div class="mt-4 flex items-center text-primary text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity transform translate-y-2 group-hover:translate-y-0">
								Voir la zone <span class="material-icons text-sm ml-1">arrow_forward</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-20 text-center">
			<h2 class="text-2xl font-bold text-white mb-6">Votre commune ne figure pas dans la liste ?</h2>
			<p class="text-gray-300 mb-8 max-w-lg mx-auto">
				Contactez-nous, nous couvrons peut-être votre zone sur demande spéciale.
			</p>
			<a href="/contact" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-xl border border-white/20 transition-all">
				<span class="material-icons">mail</span>Contacter l'équipe
			</a>
		</section>
	</main>
</Layout>
